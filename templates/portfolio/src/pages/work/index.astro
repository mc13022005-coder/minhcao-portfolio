---
import Base from "../../layouts/Base.astro";
---

<Base title="Nghiên cứu & Chiêm nghiệm — MINH CAO">
	<div class="content-wrapper">
		<!-- Phần 1: NGHIÊN CỨU -->
		<details class="category-section" open>
			<summary class="section-summary">
				<h1 class="section-title">NGHIÊN CỨU</h1>
				<span class="icon">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
						<polyline points="6 9 12 15 18 9"></polyline>
					</svg>
				</span>
			</summary>

			<div class="articles-feed">
				<article class="insight-card">
					<div class="insight-meta">
						<time datetime="2026-04">April 2026</time>
					</div>
					<h2 class="insight-title">
						<a href="#">Nghiên cứu: Tác động của Internet đến Thu nhập & Bất bình đẳng</a>
					</h2>
					<p class="insight-summary">
						Phân tích các cơ chế tác động của Internet đến thu nhập hộ gia đình thông qua các kênh vốn con người, cấu trúc lao động và Fintech.
					</p>
					<div class="insight-tags">
						<span>#Economics</span>
						<span>#DataAnalysis</span>
						<span>#Stata</span>
						<span>#UEB</span>
					</div>
				</article>
			</div>
		</details>

		<!-- Phần 2: CHIÊM NGHIỆM -->
		<details class="category-section">
			<summary class="section-summary">
				<h1 class="section-title">CHIÊM NGHIỆM</h1>
				<span class="icon">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
						<polyline points="6 9 12 15 18 9"></polyline>
					</svg>
				</span>
			</summary>

			<div class="articles-feed">
				<article class="insight-card">
					<div class="insight-meta">
						<time datetime="2026-04">April 2026</time>
					</div>
					<h2 class="insight-title">
						<a href="#">Làm giàu kiểu cụ Hồ (Tập 1)</a>
					</h2>
					<p class="insight-summary">
						Phân tích tư duy quản trị nguồn lực và triết lý kinh doanh thực tiễn áp dụng trong bối cảnh hiện đại.
					</p>
					<div class="insight-tags">
						<span>#Management</span>
						<span>#Reflection</span>
						<span>#Philosophy</span>
					</div>
				</article>
			</div>
		</details>
	</div>
</Base>

<style>
	.content-wrapper {
		max-width: 720px;
		margin: 0 auto;
		padding: var(--spacing-4xl) var(--spacing-lg);
		display: flex;
		flex-direction: column;
		gap: var(--spacing-xl);
	}

	details.category-section {
		display: flex;
		flex-direction: column;
	}

	.section-summary {
		display: flex;
		justify-content: space-between;
		align-items: center;
		cursor: pointer;
		list-style: none; /* Hide default triangle */
		padding: var(--spacing-md) 0;
		border-bottom: 1px solid rgba(0, 0, 0, 0.08); /* Faint horizontal line */
		transition: opacity var(--transition-fast);
	}

	@media (prefers-color-scheme: dark) {
		.section-summary {
			border-bottom: 1px solid rgba(255, 255, 255, 0.1);
		}
	}

	.section-summary::-webkit-details-marker {
		display: none; /* Hide default triangle in WebKit */
	}

	.section-summary:hover {
		opacity: 0.7;
	}

	.section-title {
		font-family: var(--font-serif);
		font-size: 1.35rem; /* Reduced font size */
		font-weight: 300;
		letter-spacing: 0.25em; /* Increased letter-spacing for 'Old Money' look */
		text-transform: uppercase;
		color: var(--color-text);
		margin: 0;
	}

	.section-summary .icon {
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--color-muted);
		transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
	}

	details[open] .section-summary .icon {
		transform: rotate(180deg); /* Flips the arrow when open */
	}

	.articles-feed {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3xl);
		padding-top: var(--spacing-2xl);
		padding-bottom: var(--spacing-xl);
		padding-left: var(--spacing-xl); /* Indent content elegantly */
	}

	/* Content animation */
	details[open] .articles-feed {
		animation: slideFadeDown 0.5s ease-out forwards;
	}

	@keyframes slideFadeDown {
		from {
			opacity: 0;
			transform: translateY(-8px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.insight-card {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-sm);
	}

	.insight-meta {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.insight-title {
		font-family: var(--font-serif);
		font-size: 1.6rem;
		font-weight: 400;
		line-height: 1.3;
		margin: 0;
	}

	.insight-title a {
		color: var(--color-text);
		text-decoration: none;
		transition: opacity var(--transition-fast);
	}

	.insight-title a:hover {
		opacity: 0.6;
	}

	.insight-summary {
		font-family: var(--font-sans);
		font-size: 0.95rem;
		line-height: 1.6;
		color: var(--color-muted);
		margin-top: 4px;
	}

	.insight-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		margin-top: var(--spacing-md);
	}

	.insight-tags span {
		font-family: var(--font-sans);
		font-size: 0.75rem;
		color: #666;
		background-color: rgba(0, 0, 0, 0.03);
		padding: 0.3rem 0.8rem;
		border-radius: 9999px;
		letter-spacing: 0.05em;
		border: 1px solid rgba(0, 0, 0, 0.02);
	}

	@media (prefers-color-scheme: dark) {
		.insight-tags span {
			background-color: rgba(255, 255, 255, 0.05);
			color: #aaa;
			border-color: rgba(255, 255, 255, 0.1);
		}
	}
</style>
